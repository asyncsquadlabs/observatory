# Observatory — Local Telemetry Stack
# -----------------------------------
# Copy this file to .env and customize values for your local machine.

COMPOSE_PROJECT_NAME=observatory

# Ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# Retention
PROMETHEUS_RETENTION_TIME=15d

# Security
# Change this before exposing Grafana beyond localhost!
GRAFANA_ADMIN_PASSWORD=admin
